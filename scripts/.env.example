# Marginalia Kindle Sync — configurazione
# Copia in .env e compila con i tuoi dati

# Supabase Project URL (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role Key (Settings → API → service_role — TIENILA SEGRETA)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Il tuo User ID Supabase (Authentication → Users → seleziona il tuo account → copia UUID)
SUPABASE_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
