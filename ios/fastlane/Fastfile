# Marginalia — Fastfile
# Workflow:
#   fastlane beta   → build + upload a TestFlight  (usato da GitHub Actions)
#   fastlane certs  → scarica/aggiorna certificati da Match (usato sul Mac locale)
#
# Prima di usare: leggi docs/SETUP_MAC.md

default_platform(:ios)

platform :ios do

  # ─────────────────────────────────────────────
  # Certificati via Match (solo su Mac)
  # ─────────────────────────────────────────────
  desc "Sincronizza certificati e provisioning profile da Match"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: "io.marginalia.app",
      readonly: is_ci  # read-only in CI, read-write in locale
    )
  end

  # ─────────────────────────────────────────────
  # Build + TestFlight
  # ─────────────────────────────────────────────
  desc "Build e carica su TestFlight"
  lane :beta do
    setup_ci if is_ci

    # Certificati
    match(
      type: "appstore",
      app_identifier: "io.marginalia.app",
      readonly: true,
      api_key: app_store_connect_api_key(
        key_id:      ENV["ASC_KEY_ID"],
        issuer_id:   ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        is_key_content_base64: true
      )
    )

    # Incrementa build number automaticamente
    increment_build_number(
      build_number: ENV.fetch("GITHUB_RUN_NUMBER", latest_testflight_build_number + 1),
      xcodeproj: "MarginaliaApp.xcodeproj"
    )

    # Build
    build_app(
      scheme: "MarginaliaApp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-skipMacroValidation"
    )

    # Upload a TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: app_store_connect_api_key(
        key_id:      ENV["ASC_KEY_ID"],
        issuer_id:   ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        is_key_content_base64: true
      )
    )
  end

  # ─────────────────────────────────────────────
  # Screenshots (futuro)
  # ─────────────────────────────────────────────
  desc "Genera screenshot per App Store"
  lane :screenshots do
    capture_ios_simulator_screenshots
    upload_to_app_store(skip_binary_upload: true)
  end

end
